# Runtime
PORT=8080
HOST=0.0.0.0
DATA_DIR=./.data
FRONTEND_DIR=./build
HALO_GO_MEMORY_LIMIT_MIB=48
FILE_MAX_SIZE_MB=25

# Authentication. Set a stable secret before production use.
WEBUI_SECRET_KEY=
WEBUI_AUTH_COOKIE_SECURE=false
WEBUI_AUTH_COOKIE_SAME_SITE=lax
JWT_EXPIRES_IN=-1

# Feature flags
ENABLE_SIGNUP=true
ENABLE_LOGIN_FORM=true
ENABLE_API_KEY=true
ENABLE_TERMINAL=true
ENABLE_WEBSOCKET_SUPPORT=false
ENABLE_ADMIN_CHAT_ACCESS=false
DEFAULT_USER_ROLE=pending

# Default remote model connection. Additional providers are configured in the UI.
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=

# Optional administration and integration endpoints
ENABLE_SCIM=false
SCIM_AUTH_BEARER_TOKEN=
ENABLE_ADMIN_EXPORT=false
CODE_EXECUTION_JUPYTER_URL=
CODE_EXECUTION_JUPYTER_AUTH_TOKEN=
